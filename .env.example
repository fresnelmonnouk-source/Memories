# ============================================================
# MEMORIES — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# ------------------------------------------------------------
# SUPABASE (https://supabase.com/dashboard → ton projet → API)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
# ⚠️ Clé service_role — JAMAIS exposée côté client, server-only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ------------------------------------------------------------
# GOOGLE GEMINI / NANO BANANA
# https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=AIzaSy...
# Modèle utilisé pour la génération (default: gemini-2.5-flash-image)
# Options : gemini-2.5-flash-image | gemini-3.0-flash-image | gemini-3-pro-image
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Modèle pour la modération
GEMINI_MODERATION_MODEL=gemini-2.5-flash

# ------------------------------------------------------------
# OPENAI — FALLBACK génération d'image (optionnel)
# https://platform.openai.com/api-keys
# Si absent : Gemini seul (pas de fallback). Si présent : utilisé UNIQUEMENT
# quand Gemini échoue/refuse/sature. gpt-image-1 peut exiger une org vérifiée.
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# ------------------------------------------------------------
# DEEPSEEK — assistant conseiller (visiteurs) · https://platform.deepseek.com
# API compatible OpenAI. Sans cette clé, l'assistant renvoie une erreur.
# ------------------------------------------------------------
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_CHAT_MODEL=deepseek-chat

# ------------------------------------------------------------
# STRIPE — abonnement essayage 4 €/mois (https://dashboard.stripe.com)
# Crée un Produit + Prix RÉCURRENT mensuel, copie l'ID du prix dans STRIPE_PRICE_ID.
# Le webhook secret vient de Dashboard → Developers → Webhooks (endpoint /api/stripe/webhook).
# ⚠️ Stripe ne supporte pas les comptes marchands au Togo → entité pays supporté requise,
#    sinon basculer sur FedaPay/PayDunya.
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ------------------------------------------------------------
# RESEND — emails transactionnels (https://resend.com/api-keys)
# ------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=atelier@memories.ink
RESEND_TO_EMAIL=studio@memories.ink

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STUDIO_NAME=Memories

# ------------------------------------------------------------
# CRON — nettoyage RGPD des essayages expirés (Vercel Cron)
# Vercel injecte automatiquement ce secret en header Authorization: Bearer
# sur les requêtes cron. Générer une valeur aléatoire forte.
# ------------------------------------------------------------
CRON_SECRET=change-me-random-secret
